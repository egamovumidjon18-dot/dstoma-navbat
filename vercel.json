{
  "version": 2,
  "outputDirectory": "dist",
  "functions": {
    "api/**/*": {
      "includeFiles": "firebase-applet-config.json"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
